# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Canonical origin of the deployed site (no trailing slash). Used for absolute
# URLs, metadata, sitemaps, and server-side fetches.
BASE_URL=https://example.com

# -----------------------------------------------------------------------------
# Google Generative AI (Gemini)
# -----------------------------------------------------------------------------
# API key from Google AI Studio / Cloud Console for server-side AI features.
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# -----------------------------------------------------------------------------
# Contact form (Nodemailer / SMTP)
# -----------------------------------------------------------------------------
# SMTP server hostname (e.g. your provider’s outbound host).
SMTP_HOST=smtp.example.com
# Port: 465 (SSL), 587 (STARTTLS), etc. Must match SMTP_SECURE.
SMTP_PORT=465
# true for implicit TLS (typical on 465); false for STARTTLS (typical on 587).
SMTP_SECURE=false
# Mailbox used to authenticate with SMTP.
SMTP_USER=you@example.com
# App password or SMTP password (never commit real values).
SMTP_PASS=your-smtp-password
# From address shown on outgoing mail (often same as SMTP_USER).
CONTACT_FORM_FROM_EMAIL=you@example.com
# Inbox that receives contact form submissions.
CONTACT_FORM_TO_EMAIL=hello@example.com

# -----------------------------------------------------------------------------
# OpenPanel analytics
# -----------------------------------------------------------------------------
# Script host must match `src/data/site-tracking.ts` and the privacy policy.
# These are prefixed with NEXT_PUBLIC_ and are exposed to the browser.
# Self-hosted or cloud OpenPanel API base URL (often …/api).
NEXT_PUBLIC_OPENPANEL_API_URL=https://analytics.example.com/api
# Client identifier from your OpenPanel project.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Client secret from your OpenPanel project (also public in the bundle).
NEXT_PUBLIC_OPENPANEL_CLIENT_SECRET=sec_your_openpanel_client_secret
